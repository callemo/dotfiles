theme = Kanagawa Wave
font-size = 11

# Comfortable padding around content.
window-padding-x = 8
window-padding-y = 8

# No confirmation dialog when closing a pane/window.
confirm-close-surface = false

# Hide the resize dimensions overlay.
resize-overlay = never

# Non-blinking block cursor; let vim/tmux control shape changes.
cursor-style = block
cursor-style-blink = false
shell-integration-features = no-cursor

# Linux: tmux manages tabs.
gtk-tabs-location = hidden
