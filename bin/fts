#!/usr/bin/env python3
"""
Full-text indexing and search for plain text and markdown files.

See https://www.sqlite.org/fts5.html#full_text_query_syntax for
the complete query syntax.
"""

import argparse
import sqlite3
import sys
from pathlib import Path

DB = 'fts.db'

CREATE = '''CREATE VIRTUAL TABLE IF NOT EXISTS files USING fts5 (
  file,
  content,
  indexed_at UNINDEXED,
  prefix = '2 3 4',
  tokenize = 'porter'
)'''


def index(conn):
    conn.execute(CREATE)
    for path in sorted(Path('.').rglob('*')):
        if not path.is_file() or path.suffix not in ('.txt', '.md'):
            continue
        try:
            content = path.read_text(errors='replace')
        except OSError:
            continue
        conn.execute(
            'INSERT INTO files(file, content, indexed_at) VALUES(?, ?, CURRENT_TIMESTAMP)',
            (str(path), content),
        )
    conn.commit()


def search(conn, query, *, near=False):
    q = '"' + query.replace('"', '""') + '"'
    if near:
        q = f'NEAR({q}, 100)'
    rows = conn.execute(
        "SELECT file, snippet(files, 1, '', '', '', 10) "
        "FROM files WHERE files MATCH ? ORDER BY rank",
        (q,),
    )
    for path, snippet in rows:
        print(f'{path}\t{snippet.replace(chr(10), " ")}')


def main():
    p = argparse.ArgumentParser(description=__doc__, formatter_class=argparse.RawDescriptionHelpFormatter)
    p.add_argument('-i', '--index', action='store_true', help='rebuild the index')
    p.add_argument('-n', '--near', action='store_true', help='near search (approximately same paragraph)')
    p.add_argument('query', nargs='*', help='search query')
    args = p.parse_args()

    db = Path(DB)
    if args.index and db.exists():
        db.unlink()

    if not args.index and not args.query:
        p.print_help(sys.stderr)
        raise SystemExit(2)

    conn = sqlite3.connect(DB)
    try:
        if args.index:
            index(conn)
        if args.query:
            search(conn, ' '.join(args.query), near=args.near)
    finally:
        conn.close()


if __name__ == '__main__':
    main()
