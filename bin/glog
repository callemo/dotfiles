#!/bin/sh
# usage: glog [-n num] [-v] [git-log-args...]
# Display git log in a formatted table.
#
# Options:
#   -n NUM    Number of commits to show (default: 10)
#   -v        Verbose mode with graph and stats
#
# Examples:
#   glog           Show last 10 commits
#   glog -n 5      Show last 5 commits
#   glog -v        Verbose git log with graph

usage() { sed -En '2,/^[^#]/ s/^# //p' "$0" >&2; }

n=10
v=0
while [ $# -gt 0 ]
do
	case "$1" in
	-h)
		usage
		exit 0
		;;
	-n)
		shift
		n="$1"
		shift
		;;
	-v)
		v=1
		shift
		;;
	--)
		shift
		break
		;;
	*)
		break
		;;
	esac
done

[ "$v" = 1 ] && exec git log -n "$n" --graph --stat --date=human --abbrev-commit "$@"

git log -n "$n" --date=human \
	--pretty=format:'%h	%cd	%<(11,trunc)%cn	%s' "$@" |
	awk 'BEGIN { FS = OFS = "\t" }
		{split($3, a, " "); print $1, $2, a[1], $4}' | tabfmt
