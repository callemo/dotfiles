#!/bin/sh
# usage: pp [-Dsymbol ...] [file ...]
# Pp is a minimal preprocessor.  It reads each file in sequence and
# writes it to the standard output, interpreting the directives below.
# If no file is given, the standard input is read.
#
#   #pp:ifdef S    if S is defined, emit lines up to matching endif
#   #pp:ifndef S   if S is not defined, emit lines up to matching endif
#   #pp:endif      close the innermost ifdef or ifndef
#   #pp:include F  replace this line with the contents of file F
#
# Directives may be nested to any depth.  Lines within a false block
# are suppressed; a false #pp:include is not opened.  Circular
# includes are detected and cause an error exit.
#
# Options:
#   -Dsymbol  define symbol (only membership is tested, not value)
#
# Examples:
#   pp -DPDP11 file.txt
#   pp -DPDP11 -DNOFLOAT a.txt b.txt
#   cat file.txt | pp -DSMALL
#

exec awk '
function p(f,  s, r, d0) {
	if (v[f]++) { print "pp: loop " f > "/dev/stderr"; exit 1 }
	d0 = d
	while ((r = getline s < f) > 0) {
		if (sub(/^#pp:ifdef[ \t]+/, "", s)) {
			d++
			emit[d] = emit[d-1] && (s in D)
			continue
		}
		if (sub(/^#pp:ifndef[ \t]+/, "", s)) {
			d++
			emit[d] = emit[d-1] && !(s in D)
			continue
		}
		if (s ~ /^#pp:endif/) {
			if (d > d0) d--
			else print "pp: " f ": stray endif" > "/dev/stderr"
			continue
		}
		if (!emit[d]) continue
		if (sub(/^#pp:include[ \t]+/, "", s)) { p(s); continue }
		print s
	}
	if (r < 0) {
		print "pp: " f ": cannot read" > "/dev/stderr"
		exit 1
	}
	if (d != d0) {
		print "pp: " f ": unclosed ifdef" > "/dev/stderr"
		exit 1
	}
	close(f)
	v[f]--
}
BEGIN {
	emit[0] = 1; d = 0
	for (i = 1; i < ARGC; i++) {
		if (!sub(/^-D/, "", ARGV[i])) { F[n++] = ARGV[i]; continue }
		D[ARGV[i]] = 1
	}
	if (!n) F[n++] = "-"
	for (i = 0; i < n; i++) p(F[i])
	exit
}' "$@"
