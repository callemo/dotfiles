#!/bin/sh
# tmux-load: restores a tmux session from a dump file (default: ~/tmux.dump)
#
# Creates a new detached session with the saved name and path, then recreates
# each window and pane with the saved working directory. Additional panes in a
# window are split from the window's first pane. If a pane was running vim or
# nvim, vim is restarted and Session.vim is sourced if present in that
# directory. Custom window names are restored. Finally the previously active
# window is selected, all window layouts are reapplied, and the session is
# attached. Index-agnostic: window indices from the dump are not assumed to be
# available in the new session.

awk -F'          ' '
BEGIN { pw = -1; nw = -1 }
NR == 1 { path = $0 }
NR == 2 { name = $0
          cmd = sprintf("tmux new -d -s '\''%s'\'' -c '\''%s'\''\\;", name, path) }
$1 == "p" {
    w = $2
    p = $3
    d = $4
    prog = $5
    if (w > nw) nw = w
    
    if (pw == -1) {
        # first pane of first window
        cmd = cmd sprintf(" send-keys -t %d.%d '\''cd %s'\'' Enter\\;", w, p, d)
        first_p[w] = p
    } else if (w != pw) {
        # first pane of a new window
        cmd = cmd sprintf(" neww -d -t %d -c '\''%s'\''\\;", w, d)
        first_p[w] = p
    } else {
        # subsequent pane: split the first pane of this window
        cmd = cmd sprintf(" splitw -d -t %d.%d -c '\''%s'\''\\;", w, first_p[w], d)
    }

    if (prog == "vim" || prog == "nvim") {
        if (system("test -f " d "/Session.vim") == 0)
            cmd = cmd sprintf(" send-keys -t %d.%d '\''vim -S Session.vim'\'' Enter\\;", w, p)
        else
            cmd = cmd sprintf(" send-keys -t %d.%d '\''vim'\'' Enter\\;", w, p)
    }
    pw = w
}
$1 == "w" {
    w = $2
    if ($3 ~ /\*/) cur = w
    if ($4 == 0) cmd = cmd sprintf(" renamew -t %d '\''%s'\''\\;", w, $5)
    lay[w] = $6
}
END {
    cmd = cmd " selectw -t " cur "\\;"
    for (i = 0; i <= nw; i++)
        if (i in lay)
            cmd = cmd sprintf(" selectl -t %d '\''%s'\''\\;", i, lay[i])
    system(cmd)
    system("tmux attach")
}' "${1:-$HOME/tmux.dump}"
