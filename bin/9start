#!/bin/sh

export SHELL=/bin/sh
export PS1='\$ '
export ENV="$DOTFILES/9.sh"
export EDITOR=E
export PAGER=nobs
export PATH="$DOTFILES/acme:$PATH"
export acmeshell="$SHELL"
export home="$HOME"
export user="$USER"

: "${VARFONT=/mnt/font/GoRegular/14a/font}"
: "${FIXFONT=/mnt/font/GoMono/14a/font}"

name=''
argc=$#
while [ "$argc" -gt 0 ]; do
	arg=$1; shift; argc=$((argc - 1))
	if [ "$arg" = '-n' ]; then
		if [ "$argc" -eq 0 ]; then
			echo "9start: -n requires a name" >&2
			exit 1
		fi
		name=$1; shift; argc=$((argc - 1))
	else
		set -- "$@" "$arg"
	fi
done

if [ -n "$name" ]; then
	NAMESPACE="$(${PLAN9:-/usr/local/plan9}/bin/namespace).$name"
	export NAMESPACE
	mkdir -p "$NAMESPACE"
	if [ ! -S "$NAMESPACE/plumb" ] || ! pgrep -x plumber > /dev/null 2>&1; then
		${PLAN9:-/usr/local/plan9}/bin/plumber &
	fi
else
	pgrep -x plumber > /dev/null 2>&1 || plumber &
fi

set -- -a "$@"
[ -n "$VARFONT" ] && set -- "$@" -f "$VARFONT"
[ -n "$FIXFONT" ] && set -- "$@" -F "$FIXFONT"
exec "${PLAN9:-/usr/local/plan9}/bin/acme" "$@"
