#!/bin/sh
# n: a tool for managing notes
#
# Usage:
#	n -h
#	n <command> [arguments]
#
# Commands:
#	look	find a note by its link key
#	meta	generates a note meta template
#	new	generates a new note filename
#	tag [tag ...]	list tags or notes matching all tags
#	xref	update cross references
#

case $0 in
/*) self=$0 ;;
*/*) self=$PWD/$0 ;;
*) self=$(command -v "$0" 2>/dev/null || printf '%s' "$0") ;;
esac
log() { echo "${0##*/}:" "$@" >&2; }
fatal() { log "$@"; exit 1; }
usage() { sed -En '2,/^[^#]/ s/^#[ 	]//p' "$self" >&2; }
edots() { printf '%s' "$1" | sed 's/\./\\./g'; }

main() {
	if [ $# -lt 1 ]; then
		usage
		exit 2
	fi

	case $1 in
	-h|--help)
		usage
		exit 0
		;;
	esac

	cmd=$1; shift

	cd "${NROOT:=$HOME/notes}"

	case $cmd in
	look) nlook "$@" ;;
	meta) snip nmeta "$@" ;;
	new) snip nfile "$@" ;;
	tag) ntag "$@" ;;
	xref) nxref "$@" ;;
	*) fatal "unknown command: $cmd" ;;
	esac
}

nlook() {
	if [ $# -lt 1 ]; then
		fatal 'look: too few arguments'
	fi

	p=$(edots "$1")
	nfiles | grep -Ei "(^|/)${p}[^/]*$" | sed 1q
}

ntag() {
	case $1 in
	-h|--help)
		usage
		exit 0
		;;
	esac

	nfiles | xargs grep -E -H '^[ 	]*Tags:' |
	awk 'BEGIN {
		FS = ":"
		OFS = "\t"
		for (i = 1; i < ARGC; i++) {
			if (ARGV[i] != "" && !(tolower(ARGV[i]) in query)) {
				query[tolower(ARGV[i])] = 1
				nquery += 1
			}
			delete ARGV[i]
		}
	}
	{
		sub(/^[.]\//, "", $1)
		gsub("[ 	#]+", " ", $3)
		split($3, a, " ")
		for (tag in have)
			delete have[tag]
		for (i in a) {
			tag = tolower(a[i])
			if (tag == "")
				continue
			if (nquery == 0)
				tags[tag] += 1
			else
				have[tag] = 1
		}
		if (nquery != 0) {
			ok = 1
			for (tag in query) {
				if (!(tag in have)) {
					ok = 0
					break
				}
			}
			if (ok)
				print $1
		}
	}
	END {
		if (nquery == 0)
			for (i in tags)
				print tags[i], i |"sort -k2"
	}' "$@"
}

nxref() {
	tmp=$(mktemp)
	nfiles >"$tmp"
	trap 'rm -f "$tmp"' EXIT
	nrevlinks |
		awk 'BEGIN { FS = OFS = "\t" }
		{
			gsub(/[\[\]]+/, "", $1)
			sub(/^(Z\/R\/|Z\/R\/n\/)/, "", $1)
			printf "%s\t",  $1
			split($2, a, /,/)
			for (i in a) {
				sub(/^\.\/(Z\/R\/|Z\/R\/n\/)?/, "", a[i])
				sub(/\.(md|txt)$/, "", a[i])
				printf " [[%s]]", a[i]
			}
			printf "\n"
		}' |
		while IFS='	' read -r key refs; do
			set -- $refs
			if [ $# -gt 0 ]; then
				refs=" $(printf '%s\n' "$@" | sort | paste -sd' ' -)"
			else
				refs=
			fi
			key=$(edots "$key")
			f="$(grep -Ei "(^|/)${key}[^/]*$" "$tmp" | sed 1q)"
			if [ -z "$f" ]; then
				log "xref: file not found: following [[$key]] from$refs"
				continue
			fi
			sed -E -e '/^---/,/^---/s@^References:.*@References:'"$refs"'@' -i.bak "$f"
			rm -f "$f".bak
		done
}

nrevlinks() {
	nlinks |
		awk 'BEGIN { FS = OFS = "\t" }
		{
			split($2, a, /,/)
			for (i in a) {
				key = a[i]
				gsub(/[\[\]]+/, "", key)
				sub(/^(Z\/R\/|Z\/R\/n\/)/, "", key)
				if (!seen[key, $1]++)
					rlinks[key] = rlinks[key] $1 ","
			}
		}
		END {
			for (k in rlinks) {
				delete cand
				nc = 0
				for (m in rlinks)
					if (k != m && length(k) < length(m) && \
					   (substr(m, 1, length(k)) == k || \
					    substr(m, length(m) - length(k)) == "/" k)) {
						cand[nc++] = m
					}
				if (nc == 1)
					merge[k] = cand[0]
			}
			for (k in merge) {
				m = merge[k]
				n = split(rlinks[k], srcs, /,/)
				for (j = 1; j <= n; j++)
					if (srcs[j] != "" && !seen[m, srcs[j]]++)
						rlinks[m] = rlinks[m] srcs[j] ","
				delete rlinks[k]
			}
			for (src in rlinks) {
				sub(/,$/, "", rlinks[src])
				print src, rlinks[src]
			}
		}'
}

nlinks() {
	grep -ERI '\[\[[0-9A-Za-z_/.-]+\]\]' . | grep -Ev '^[^:]+:References:' | sort |
		awk 'BEGIN { FS = ":"; OFS = "\t" }
		{
			line = $0
			while(match(line, /\[\[[0-9A-Za-z_\/.-]+\]\]/)) {
				l = substr(line, RSTART, RLENGTH)
				if (!index(links[$1], l))
					links[$1] = links[$1] l ","
				line = substr(line, RSTART+RLENGTH)
			}
		}
		END {
			for (file in links) {
				sub(/,$/, "", links[file])
				print file, links[file]
			}
		}'
}

nfiles() {
	find -L "$PWD" -type f | grep -E '\.(txt|md)$' | sort
}

main "$@"
