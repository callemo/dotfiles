#!/bin/sh
# n: a tool for managing notes
#
# Usage:
#	n -h
#	n <command> [arguments]
#
# Commands:
#	look	find a note by its link key
#	meta	generates a note meta template
#	new	generates a new note filename
#	tag [tag ...]	list tags or notes matching all tags
#	xref	update cross references
#

case $0 in
/*) self=$0 ;;
*/*) self=$PWD/$0 ;;
*) self=$(command -v "$0" 2>/dev/null || printf '%s' "$0") ;;
esac
log() { echo "${0##*/}:" "$@" >&2; }
fatal() { log "$@"; exit 1; }
usage() { sed -En '2,/^[^#]/ s/^#[ 	]//p' "$self" >&2; }
edots() { printf '%s' "$1" | sed 's/\./\\./g'; }

main() {
	if [ $# -lt 1 ]; then
		usage
		exit 2
	fi

	case $1 in
	-h|--help)
		usage
		exit 0
		;;
	esac

	cmd=$1; shift

	cd "${NROOT:=$HOME/notes}"

	case $cmd in
	look) nlook "$@" ;;
	meta) snip nmeta "$@" ;;
	new) snip nfile "$@" ;;
	tag) ntag "$@" ;;
	xref) exec python3 "${self%/*}/xref.py" "$PWD" ;;
	*) fatal "unknown command: $cmd" ;;
	esac
}

nlook() {
	if [ $# -lt 1 ]; then
		fatal 'look: too few arguments'
	fi

	p=$(edots "$1")
	nfiles | grep -Ei "(^|/)${p}[^/]*$" | sed 1q
}

ntag() {
	case $1 in
	-h|--help)
		usage
		exit 0
		;;
	esac

	nfiles | xargs grep -E -H '^[ 	]*Tags:' |
	awk 'BEGIN {
		FS = ":"
		OFS = "\t"
		for (i = 1; i < ARGC; i++) {
			if (ARGV[i] != "" && !(tolower(ARGV[i]) in query)) {
				query[tolower(ARGV[i])] = 1
				nquery += 1
			}
			delete ARGV[i]
		}
	}
	{
		sub(/^[.]\//, "", $1)
		gsub("[ 	#]+", " ", $3)
		split($3, a, " ")
		for (tag in have)
			delete have[tag]
		for (i in a) {
			tag = tolower(a[i])
			if (tag == "")
				continue
			if (nquery == 0)
				tags[tag] += 1
			else
				have[tag] = 1
		}
		if (nquery != 0) {
			ok = 1
			for (tag in query) {
				if (!(tag in have)) {
					ok = 0
					break
				}
			}
			if (ok)
				print $1
		}
	}
	END {
		if (nquery == 0)
			for (i in tags)
				print tags[i], i |"sort -k2"
	}' "$@"
}

nfiles() {
	find -L "$PWD" -type f | grep -E '\.(txt|md)$' | sort
}

main "$@"
