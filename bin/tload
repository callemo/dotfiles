#!/bin/sh
# tload: restore tmux session from a tdump dump

f="${1:-$HOME/tmux.dump}"
[ ! -f "$f" ] && { echo "no dump file: $f" >&2; exit 1; }

tmp=$(mktemp -d "${TMPDIR:-/tmp}/tload.XXXXXX") || exit 1
trap 'rm -rf "$tmp"' 0

tab='	'

q() {
	printf "'%s'" "$(printf '%s' "$1" | sed "s/'/'\\\\''/g")"
}

put() {
	key=$1
	val=$2
	printf '%s\n' "$val" >"$sessdir/$key"
}

get() {
	key=$1
	[ -f "$sessdir/$key" ] || return 1
	IFS= read -r value <"$sessdir/$key" || return 1
	printf '%s' "$value"
}

uniq_sess() {
	base=$1
	name=$base
	i=

	while tmux has-session -t "$name" 2>/dev/null; do
		if [ -z "$i" ]; then
			i=1
			name=${base}-restored
		else
			i=$((i + 1))
			name=${base}-restored-$i
		fi
	done

	printf '%s' "$name"
}

vim_restore() {
	pane=$1
	vimdir=$2
	prog=$3

	case $prog in
	vim)
		if [ -f "$vimdir/vim.dump" ]; then
			tmux send-keys -t "$pane" "vim -c $(q "Load $vimdir/vim.dump")" C-m
		elif [ -f "$vimdir/Session.vim" ]; then
			tmux send-keys -t "$pane" 'vim -S Session.vim' C-m
		else
			tmux send-keys -t "$pane" 'vim' C-m
		fi
		;;
	esac
}

defer_vim() {
	pane=$1
	vimdir=$2
	prog=$3
	[ "$prog" = vim ] || return 0

	{
		printf '%s\n' "$pane"
		printf '%s\n' "$vimdir"
	} >>"$tmp/vim.order"
}

replay_vim() {
	[ -f "$tmp/vim.order" ] || return 0
	while IFS= read -r pane; do
		IFS= read -r dir || return 1
		vim_restore "$pane" "$dir" vim
	done <"$tmp/vim.order"
}

vim_size() {
	while IFS= read -r pane; do
		IFS= read -r vimdir || return 1
		tmux display-message -p -t "$pane" '#{pane_width}x#{pane_height}' || return 1
	done <"$tmp/vim.order"
}

wait_vim() {
	[ -f "$tmp/vim.order" ] || return 0

	i=0
	while [ -z "$(tmux list-clients -t "$firstsess" 2>/dev/null)" ]; do
		i=$((i + 1))
		[ "$i" -lt 100 ] || return 1
		sleep 0.05
	done

	last=
	i=0
	while :; do
		size=$(vim_size) || return 1
		[ "$size" = "$last" ] && return 0
		last=$size
		i=$((i + 1))
		[ "$i" -lt 100 ] || return 1
		sleep 0.05
	done
}

finish() {
	[ -n "$sess" ] || return 0

	if [ -f "$sessdir/window.order" ]; then
		while IFS= read -r w; do
			layout=$(get "w.$w.layout") || continue
			win=$(get "w.$w.id") || continue
			tmux select-layout -t "$win" "$layout"
		done <"$sessdir/window.order"
	fi

	if [ -n "$activewin" ]; then
		win=$(get "w.$activewin.id")
		[ -n "$win" ] && tmux select-window -t "$win"
	fi
}

sess=
sesspath=
sessdir=
firstwin=
firstsess=
activewin=
sessn=0

while IFS= read -r kind; do
	case $kind in
	'')
		continue
		;;
	s)
		finish || exit 1
		IFS= read -r sesspath || exit 1
		IFS= read -r sessname || exit 1
		sessn=$((sessn + 1))
		sessdir=$tmp/$sessn
		mkdir "$sessdir" || exit 1
		firstwin=
		activewin=
		sess=$(uniq_sess "$sessname") || exit 1
		[ -n "$firstsess" ] || firstsess=$sess
		ids=$(tmux new-session -d -P -F "#{window_id}${tab}#{pane_id}" -s "$sess" -c "$sesspath") || exit 1
		put first.win "${ids%%"$tab"*}"
		put first.pane "${ids#*"$tab"}"
		;;
	w)
		IFS= read -r w || exit 1
		IFS= read -r flags || exit 1
		IFS= read -r auto || exit 1
		IFS= read -r name || exit 1
		IFS= read -r layout || exit 1
		[ -n "$firstwin" ] || firstwin=$w
		case $flags in
		*\**)
			activewin=$w
			;;
		esac
		put "w.$w.auto" "$auto"
		put "w.$w.name" "$name"
		put "w.$w.layout" "$layout"
		printf '%s\n' "$w" >>"$sessdir/window.order"
		;;
	p)
		IFS= read -r w || exit 1
		IFS= read -r paneidx || exit 1
		IFS= read -r panedir || exit 1
		IFS= read -r prog || exit 1

		if get "w.$w.id" >/dev/null 2>&1; then
			win=$(get "w.$w.id")
			last=$(get "w.$w.last")
			pane=$(tmux split-window -d -P -F '#{pane_id}' -t "$last" -c "$panedir") || exit 1
			put "w.$w.last" "$pane"
			defer_vim "$pane" "$panedir" "$prog"
			continue
		fi

		if [ "$w" = "$firstwin" ]; then
			win=$(get first.win)
			pane=$(get first.pane)
			[ "$panedir" != "$sesspath" ] && tmux send-keys -t "$pane" "cd -- $(q "$panedir")" C-m
		else
			ids=$(tmux new-window -d -P -F "#{window_id}${tab}#{pane_id}" -t "$sess:$w" -c "$panedir") || exit 1
			win=${ids%%"$tab"*}
			pane=${ids#*"$tab"}
		fi

		put "w.$w.id" "$win"
		auto=$(get "w.$w.auto")
		name=$(get "w.$w.name")
		case $auto in
		0)
			tmux rename-window -t "$win" "$name"
			tmux set-window-option -t "$win" automatic-rename off
			;;
		1)
			tmux set-window-option -t "$win" automatic-rename on
			;;
		esac

		put "w.$w.last" "$pane"
		defer_vim "$pane" "$panedir" "$prog"
		;;
	esac
done <"$f"

finish || exit 1

if [ -n "$TMUX" ]; then
	tmux switch-client -t "$firstsess"
	wait_vim
	replay_vim
else
	(wait_vim; replay_vim) &
	pid=$!
	tmux attach-session -t "$firstsess"
	rc=$?
	[ "$rc" -eq 0 ] || kill "$pid" 2>/dev/null
	wait "$pid" 2>/dev/null
	exit "$rc"
fi
