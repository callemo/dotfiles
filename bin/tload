#!/bin/sh
# tload: restore tmux session from a tdump dump

f="${1:-$HOME/tmux.dump}"
[ ! -f "$f" ] && { echo "no dump file: $f" >&2; exit 1; }

tmp=$(mktemp -d "${TMPDIR:-/tmp}/tload.XXXXXX") || exit 1
trap 'rm -rf "$tmp"' 0

q() {
	printf "'%s'" "$(printf '%s' "$1" | sed "s/'/'\\\\''/g")"
}

put() {
	printf '%s\n' "$2" > "$tmp/$1"
}

get() {
	[ -f "$tmp/$1" ] || return 1
	IFS= read -r value < "$tmp/$1" || return 1
	printf '%s' "$value"
}

uniq_sess() {
	base=$1
	name=$base
	i=

	while tmux has-session -t "$name" 2>/dev/null; do
		if [ -z "$i" ]; then
			i=1
			name=${base}-restored
		else
			i=$((i + 1))
			name=${base}-restored-$i
		fi
	done

	printf '%s' "$name"
}

vim_restore() {
	pane=$1
	dir=$2
	prog=$3

	case $prog in
	*vim*)
		if [ -f "$dir/vim.dump" ]; then
			tmux send-keys -t "$pane" "vim -c 'Load $dir/vim.dump'" C-m
		elif [ -f "$dir/Session.vim" ]; then
			tmux send-keys -t "$pane" 'vim -S Session.vim' C-m
		else
			tmux send-keys -t "$pane" 'vim' C-m
		fi
		;;
	esac
}

sess=
spath=
first=
active=

while IFS= read -r kind; do
	case $kind in
	'')
		continue
		;;
	s)
		IFS= read -r spath || exit 1
		IFS= read -r sname || exit 1
		sess=$(uniq_sess "$sname") || exit 1
		set -- $(tmux new-session -d -P -F '#{window_id}	#{pane_id}' -s "$sess" -c "$spath") || exit 1
		put first.win "$1"
		put first.pane "$2"
		;;
	w)
		IFS= read -r w || exit 1
		IFS= read -r flags || exit 1
		IFS= read -r _ || exit 1
		IFS= read -r _ || exit 1
		IFS= read -r layout || exit 1
		[ -n "$first" ] || first=$w
		case $flags in
		*\**)
			active=$w
			;;
		esac
		put "w.$w.layout" "$layout"
		printf '%s\n' "$w" >> "$tmp/window.order"
		;;
	p)
		IFS= read -r w || exit 1
		IFS= read -r _ || exit 1
		IFS= read -r d || exit 1
		IFS= read -r prog || exit 1

		if ! get "w.$w.id" >/dev/null 2>&1; then
			if [ "$w" = "$first" ]; then
				win=$(get first.win)
				pane=$(get first.pane)
				if [ "$d" != "$spath" ]; then
					tmux send-keys -t "$pane" "cd -- $(q "$d")" C-m
				fi
			else
				set -- $(tmux new-window -d -P -F '#{window_id}	#{pane_id}' -t "$sess:$w" -c "$d") || exit 1
				win=$1
				pane=$2
			fi

			put "w.$w.id" "$win"
			put "w.$w.anchor" "$pane"

		else
			win=$(get "w.$w.id")
			anchor=$(get "w.$w.anchor")
			pane=$(tmux split-window -d -P -F '#{pane_id}' -t "$anchor" -c "$d") || exit 1
		fi

		vim_restore "$pane" "$d" "$prog"
		;;
	esac
done < "$f"

if [ -f "$tmp/window.order" ]; then
	while IFS= read -r w; do
		layout=$(get "w.$w.layout") || continue
		win=$(get "w.$w.id") || continue
		tmux select-layout -t "$win" "$layout"
	done < "$tmp/window.order"
fi

if [ -n "$active" ]; then
	win=$(get "w.$active.id")
	[ -n "$win" ] && tmux select-window -t "$win"
fi

if [ -n "$TMUX" ]; then
	tmux switch-client -t "$sess"
else
	tmux attach-session -t "$sess"
fi
