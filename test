#!/bin/sh
# test - run basic tests for dotfiles programs

: "${DOTFILES:=$(pwd)}"

case $(uname) in
Linux) sed() { command sed -l 4096 "$@"; } ;;
*)     export COLUMNS=4096 ;;
esac

# Normalize output so diffs track program changes, not host rendering quirks.
normalize() {
	sed -e 's|/tmp/test1\.[0-9]*|TMPFILE|g' \
	    -e 's|/tmp/rgsub_test\.[0-9]*|TESTDIR|g' |
		"$DOTFILES/bin/vis"
}

testvimrc() {
	if ! command -v vim >/dev/null 2>&1; then
		echo "Skipping Vim tests: vim not found"
		return 0
	fi
	if ! output=$(vim -Nu NONE -n -es -S "$DOTFILES/test.vim" 2>&1); then
		echo "Vim tests failed" >&2
		echo "$output" >&2
		exit 1
	fi
}

testsnip() {
	if ! output=$(PYTHONPATH=$DOTFILES python3 -m unittest test_snip.py 2>&1); then
		echo "Unit tests failed" >&2
		echo "$output" >&2
		exit 1
	fi
}

testsnip
testvimrc
out=$(mktemp)
trap 'rm -f "$out" fts.db' EXIT
env - PATH="$DOTFILES/bin:$PATH" \
	HOME="$HOME" DOTFILES="$DOTFILES" \
	sh test.sh 2>&1 | normalize >"$out"
diff -u test.exp "$out"
